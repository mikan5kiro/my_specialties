/** 组件样式 - 拿手菜小程序 */
@import './variables.wxss';

/* ========== 页面头部 ========== */
.page-header {
  background: var(--color-bg);
  padding: var(--space-lg) var(--space-md) var(--space-sm);
  display: flex;
  align-items: center;
  gap: var(--space-md);
}

.page-header-icon {
  font-size: 56rpx;
  flex-shrink: 0;
}

.page-header-text {
  flex: 1;
}

.page-header-title {
  font-size: var(--font-size-xxl);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
}

.page-header-subtitle {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-top: var(--space-xs);
}

/* ========== 搜索框 ========== */
.search-bar {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: var(--space-sm) var(--space-md);
  margin: var(--space-md);
  display: flex;
  align-items: center;
  border: 1rpx solid var(--color-border-input);
}

.search-bar-icon {
  color: var(--color-text-muted);
  margin-right: var(--space-sm);
  font-size: var(--font-size-lg);
}

.search-bar-input {
  flex: 1;
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  border: none;
  background: transparent;
}

/* ========== 排序和筛选栏 ========== */
.sort-filter-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 var(--space-md);
}

/* ========== 排序下拉菜单 ========== */
.sort-dropdown {
  position: relative;
  flex: 1;
}

.sort-dropdown-trigger {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: var(--space-sm) var(--space-md);
  display: flex;
  align-items: center;
  justify-content: space-between;
  border: 1rpx solid var(--color-border-input);
}

.sort-dropdown-icon {
  color: var(--color-star);
  margin-right: var(--space-sm);
  font-size: var(--font-size-base);
}

.sort-dropdown-text {
  flex: 1;
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
}

.sort-dropdown-arrow {
  color: var(--color-text-muted);
  font-size: var(--font-size-sm);
  margin-left: var(--space-sm);
}

.sort-dropdown-menu {
  position: absolute;
  top: 100%;
  left: 0;
  right: 0;
  margin-top: var(--space-xs);
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-lg);
  padding: var(--space-xs);
  z-index: 100;
}

.sort-dropdown-item {
  display: flex;
  align-items: center;
  padding: var(--space-sm) var(--space-md);
  border-radius: var(--radius-sm);
  transition: background var(--transition-fast);
}

.sort-dropdown-item:active,
.sort-dropdown-item.active {
  background: var(--color-bg-tag);
}

.sort-dropdown-item-icon {
  margin-right: var(--space-sm);
  font-size: var(--font-size-base);
}

/* ========== 分割线 ========== */
.divider-line {
  height: 1rpx;
  background: var(--color-border-divider);
  margin: var(--space-md) var(--space-md) var(--space-sm);
}

/* ========== 筛选按钮 ========== */
.filter-toggle-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-sm) var(--space-md);
  background: var(--color-bg-card);
  border-radius: var(--radius-full);
  margin-left: var(--space-sm);
  border: 1rpx solid var(--color-border);
}

.filter-toggle-icon {
  font-size: var(--font-size-sm);
  margin-right: 4rpx;
}

.filter-toggle-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

/* ========== 标签筛选区 ========== */
.filter-section {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  margin: 0 var(--space-md) var(--space-md);
}

.filter-group {
  padding: 0 var(--space-md);
  border-bottom: 1rpx solid var(--color-border);
}

.filter-group:last-child {
  border-bottom: none;
}

.filter-group-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-sm) 0;
}

.filter-group-title {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  font-weight: var(--font-weight-medium);
}

.filter-group-arrow {
  font-size: var(--font-size-xs);
  color: var(--color-text-muted);
  transition: transform var(--transition-fast);
}

.filter-group-body {
  padding-bottom: var(--space-sm);
  position: relative;
}

.scroll-indicator {
  position: absolute;
  right: 8rpx;
  bottom: var(--space-sm);
  font-size: var(--font-size-xs);
  color: var(--color-text-muted);
  animation: scrollHint 1.5s ease-in-out infinite;
}

@keyframes scrollHint {
  0%, 100% {
    opacity: 0.4;
    transform: translateX(0);
  }
  50% {
    opacity: 0.8;
    transform: translateX(8rpx);
  }
}

.filter-group-scroll {
  white-space: nowrap;
}

.filter-group-content {
  display: inline-flex;
  gap: var(--space-sm);
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  background: var(--color-bg-tag);
  color: var(--color-text-secondary);
  border-radius: var(--radius-full);
  font-size: var(--font-size-xs);
  border: 2rpx solid var(--color-border-input);
  transition: all var(--transition-fast);
}

.filter-chip.active {
  background: #ffb900;
  color: var(--color-text-secondary);
  border-color: #ffb900;
  box-shadow: 0 4rpx 12rpx rgba(255, 185, 0, 0.25);
}

.search-bar-input::placeholder {
  color: var(--color-text-placeholder);
}

.search-bar-clear {
  color: var(--color-text-muted);
  padding: var(--space-xs);
}

/* ========== 筛选标签栏 ========== */
.filter-bar {
  display: flex;
  flex-wrap: nowrap;
  padding: var(--space-sm) var(--space-md);
  gap: var(--space-sm);
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.filter-bar::-webkit-scrollbar {
  display: none;
}

.filter-tag {
  padding: 12rpx 24rpx;
  border-radius: var(--radius-full);
  font-size: var(--font-size-sm);
  background: var(--color-bg-tag);
  color: var(--color-text-secondary);
  white-space: nowrap;
  transition: all var(--transition-fast);
  border: 2rpx solid transparent;
}

.filter-tag.active {
  background: var(--color-primary);
  color: var(--color-text-light);
  box-shadow: var(--shadow-sm);
}

.filter-tag.outline {
  background: transparent;
  border-color: var(--color-border);
}

.filter-tag.outline.active {
  background: var(--color-primary);
  border-color: var(--color-primary);
}

/* ========== Tab 切换 ========== */
.tab-bar {
  display: flex;
  justify-content: space-around;
  padding: var(--space-md) var(--space-lg);
  border-bottom: 2rpx solid var(--color-border);
  background: var(--color-bg-card);
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
  padding: var(--space-sm) var(--space-md);
  position: relative;
  transition: color var(--transition-fast);
}

.tab-item.active {
  color: var(--color-primary);
  font-weight: var(--font-weight-bold);
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: var(--color-primary);
  border-radius: 2rpx;
}

/* ========== 菜谱卡片 ========== */
.recipe-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
  margin-bottom: var(--space-md);
  transition: transform var(--transition-fast), box-shadow var(--transition-fast);
  display: flex;
  align-items: center;
  position: relative;
}

.recipe-card:active {
  transform: translateY(-2rpx);
  box-shadow: var(--shadow-lg);
}

.recipe-card-image-wrap {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  flex-shrink: 0;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: var(--space-md) var(--space-sm) var(--space-md) var(--space-md);
  border-radius: var(--radius-md);
}

.recipe-card-image {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.recipe-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-sm);
}

.recipe-card-tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  background: var(--color-bg-tag);
  color: var(--color-text-secondary);
  border-radius: var(--radius-full);
  font-size: var(--font-size-xs);
  border: 1rpx solid var(--color-border-input);
}

.recipe-card-info {
  flex: 1;
  padding: var(--space-md);
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.recipe-card-title {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recipe-card-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.recipe-card-rating {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
}

.recipe-card-rating .star {
  color: var(--color-star);
  font-size: var(--font-size-sm);
}

.recipe-card-rating .score {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  font-weight: var(--font-weight-medium);
}

.recipe-card-count {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
  color: var(--color-heart);
  font-size: var(--font-size-sm);
}

/* 单列列表布局 */
.recipe-grid {
  padding: var(--space-md);
}

/* ========== 悬浮添加按钮 ========== */
.fab {
  position: fixed;
  bottom: var(--space-xl);
  right: var(--space-xl);
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-lg);
  color: var(--color-text-light);
  font-size: 48rpx;
  font-weight: 300;
  z-index: 100;
  transition: transform var(--transition-fast), box-shadow var(--transition-fast);
}

.fab:active {
  transform: scale(0.95);
  box-shadow: var(--shadow-xl);
}

/* ========== 详情页头部 ========== */
.detail-header {
  position: relative;
  height: 480rpx;
}

.detail-header-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 0 0 var(--radius-xl) var(--radius-xl);
}

.detail-header-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: var(--space-xl) var(--space-md) var(--space-lg);
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.6));
  border-radius: 0 0 var(--radius-xl) var(--radius-xl);
}

.detail-header-title {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-light);
}

.detail-header-tag {
  display: inline-block;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(8rpx);
  padding: 6rpx 16rpx;
  border-radius: var(--radius-md);
  font-size: var(--font-size-xs);
  color: var(--color-text-light);
  margin-top: var(--space-xs);
}

.detail-meta-bar {
  display: flex;
  gap: var(--space-lg);
  padding: var(--space-md) var(--space-md);
  color: var(--color-text-secondary);
  font-size: var(--font-size-sm);
}

.detail-meta-item {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
}

/* ========== 详情页区块 ========== */
.section {
  margin-bottom: var(--space-lg);
}

.section-header {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  margin: var(--space-lg) var(--space-md) var(--space-md);
}

.section-icon {
  width: 40rpx;
  height: 40rpx;
  background: var(--color-bg-tag);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-primary);
  font-size: var(--font-size-sm);
}

.section-title {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
}

/* ========== 食材列表 ========== */
.ingredient-list {
  padding: 0 var(--space-md);
}

.ingredient-item {
  padding: var(--space-sm) 0;
  border-bottom: 1rpx solid var(--color-border-light);
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  display: flex;
  align-items: center;
}

.ingredient-item::before {
  content: '•';
  color: var(--color-primary);
  margin-right: var(--space-sm);
  font-size: var(--font-size-lg);
}

.ingredient-item:last-child {
  border-bottom: none;
}

/* ========== 步骤列表 ========== */
.step-list {
  padding: 0 var(--space-md);
}

.step-item {
  display: flex;
  gap: var(--space-md);
  margin-bottom: var(--space-lg);
}

.step-number {
  width: 48rpx;
  height: 48rpx;
  background: var(--color-bg-tag);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-primary);
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-bold);
  flex-shrink: 0;
}

.step-content {
  flex: 1;
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  line-height: 1.6;
  padding-top: 8rpx;
}

/* ========== 小贴士 ========== */
.tips-box {
  margin: var(--space-md);
  padding: var(--space-md);
  background: var(--color-bg-section);
  border-radius: var(--radius-md);
  border-left: 6rpx solid var(--color-primary);
}

.tips-box-title {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
  margin-bottom: var(--space-xs);
}

.tips-box-content {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  line-height: 1.6;
}

/* ========== 操作按钮区 ========== */
.action-bar {
  padding: var(--space-md);
  background: var(--color-bg-card);
  border-top: 1rpx solid var(--color-border);
  position: sticky;
  bottom: 0;
}

.action-button {
  width: 100%;
  padding: var(--space-md);
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  border-radius: var(--radius-lg);
  text-align: center;
  color: var(--color-text-light);
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  box-shadow: var(--shadow-md);
  transition: all var(--transition-fast);
  border: none;
}

.action-button::after {
  border: none;
}

.action-button:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-sm);
}

/* ========== 星级评分 ========== */
.rating-stars {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
}

.rating-star {
  font-size: var(--font-size-lg);
  color: var(--color-border);
  transition: color var(--transition-fast);
}

.rating-star.active {
  color: var(--color-star);
}

.rating-star.half {
  position: relative;
}

/* ========== 开关组件 ========== */
.switch-wrap {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.switch-label {
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
}

/* ========== 图片上传 ========== */
.image-upload {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed var(--color-border);
  border-radius: var(--radius-md);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: var(--color-text-muted);
  background: var(--color-bg-input);
  transition: all var(--transition-fast);
}

.image-upload:active {
  border-color: var(--color-primary);
  color: var(--color-primary);
  background: var(--color-bg-tag);
}

.image-upload-icon {
  font-size: 48rpx;
  margin-bottom: var(--space-xs);
}

.image-upload-text {
  font-size: var(--font-size-xs);
}

/* ========== 解析结果预览 ========== */
.parse-preview {
  background: var(--color-bg-section);
  border-radius: var(--radius-md);
  padding: var(--space-md);
  margin: var(--space-md) 0;
}

.parse-preview-item {
  margin-bottom: var(--space-md);
}

.parse-preview-item:last-child {
  margin-bottom: 0;
}

.parse-preview-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-bottom: var(--space-xs);
  font-weight: var(--font-weight-medium);
}

.parse-preview-content {
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  line-height: 1.5;
}
