/** 全局样式变量 - 拿手菜小程序（根据设计稿提取） */

page {
/* ========== 颜色方案（优化覆盖版） ========== */

/* 主色调 - 更柔和的暖橙 */
--color-primary: #ffb900;
--color-primary-light: #FFD27A;
--color-primary-dark: #D48806;

/* 背景色 - 更偏米色（关键） */
--color-bg: #FFFBEB;
--color-bg-card: #fffefb;
--color-bg-tag: #FFFBEB;
--color-bg-section: #FBF7F0;
--color-bg-input: #F8F3EB;

/* 文字色 - 降低对比，更高级 */
--color-text-primary: #7b3306;
--color-text-secondary: #ca4d00;
--color-text-muted: #999999;
--color-text-light: #7b3306;
--color-text-placeholder: #848482;

/* 功能色 - 稍微柔一点 */
--color-star: #F5B50A;
--color-heart: #FF6B81;
--color-success: #27AE60;
--color-warning: #F39C12;
--color-error: #E74C3C;

/* 边框与阴影 - 更轻 */
--color-border: #E6D9C8;
--color-border-light: #EFE5D8;
--color-border-input: #fee685;
--color-border-divider: #fef0b8;
--color-shadow: rgba(0, 0, 0, 0.08);
--color-shadow-dark: rgba(0, 0, 0, 0.12);

  /* ========== 字体方案 ========== */
  --font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;

  /* 字号层级 */
  --font-size-xs: 22rpx;
  --font-size-sm: 24rpx;
  --font-size-base: 28rpx;
  --font-size-lg: 32rpx;
  --font-size-xl: 36rpx;
  --font-size-xxl: 48rpx;

  /* 字重 */
  --font-weight-normal: 400;
  --font-weight-medium: 500;
  --font-weight-bold: 700;

  /* ========== 间距方案 ========== */
  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 48rpx;
  --space-xxl: 64rpx;

  /* ========== 圆角方案 ========== */
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  --radius-full: 9999rpx;

  /* ========== 阴影方案 ========== */
  --shadow-sm: 0 2rpx 8rpx rgba(227, 223, 209, 0.3);
  --shadow-md: 0 4rpx 16rpx rgba(227, 223, 209, 0.4);
  --shadow-lg: 0 8rpx 32rpx rgba(227, 223, 209, 0.5);
  --shadow-xl: 0 12rpx 48rpx rgba(227, 223, 209, 0.6);

  /* ========== 动画方案 ========== */
  --transition-fast: 0.15s ease;
  --transition-base: 0.3s ease;
  --transition-slow: 0.5s ease;
}
