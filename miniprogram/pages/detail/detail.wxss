/** 详情页样式 - 所有内容合并为一个卡片 */
@import '../../styles/variables.wxss';

.detail-container {
  min-height: 100vh;
  background: var(--color-bg);
  padding: 24rpx;
}

/* ========== 唯一卡片 ========== */
.detail-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

/* ========== 图片区域：标题/标签覆盖在图片上 ========== */
.detail-image-wrap {
  position: relative;
  width: 100%;
  height: 400rpx;
  overflow: hidden;
}

.detail-cover {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* 图片上的渐变遮罩 + 标题/标签 */
.detail-image-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 80rpx 24rpx 24rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.6) 0%, rgba(0, 0, 0, 0.2) 60%, transparent 100%);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.detail-title {
  display: block;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: var(--font-weight-bold);
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

/* ========== 标签区域（在图片上） ========== */
.detail-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.detail-tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-full);
  font-size: var(--font-size-xs);
  border: 2rpx solid var(--color-border-input);
}

/* 所有标签统一为未选中样式 */
.ingredient-tag,
.type-tag,
.scene-tag {
  background: var(--color-bg-tag);
  color: var(--color-text-secondary);
  border-color: var(--color-border-input);
}

/* ========== 信息栏 ========== */
.detail-info-bar {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 16rpx 24rpx;
  background: var(--color-bg-card);
  border-bottom: 1rpx solid var(--color-border-divider);
}

.info-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.info-icon {
  font-size: 28rpx;
}

.info-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

/* ========== 内容区域（卡片内部） ========== */
.detail-content-section {
  padding: 16rpx 32rpx 24rpx;
}

/* 区域之间用细线分隔，但食材区域内部没有分割线 */
.detail-content-section + .detail-content-section {
  border-top: 1rpx solid var(--color-border-divider);
}

.section-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
  margin-left: -4rpx;
}

.section-icon {
  font-size: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
}

/* ========== 食材列表（无分割线） ========== */
.ingredients-list {
  display: flex;
  flex-direction: column;
}

.ingredient-item {
  display: flex;
  align-items: center;
  padding: 10rpx 0;
  border-bottom: none !important;
}

.ingredient-name {
  font-size: 28rpx;
  color: var(--color-text-dark);
  line-height: 1.5;
}

/* ========== 做法步骤 ========== */
.steps-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.step-item {
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
}

.step-number {
  width: 48rpx;
  height: 48rpx;
  background: var(--color-primary);
  color: var(--color-text-light);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: var(--font-weight-bold);
  flex-shrink: 0;
}

.step-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-dark);
  line-height: 1.6;
  padding-top: 4rpx;
}

/* ========== 小贴士区域 ========== */
.tip-section {
  background: linear-gradient(135deg, #fff8e7 0%, #fff5d6 100%);
  border-radius: var(--radius-md);
  padding: 16rpx 20rpx;
}

.tip-section .section-header {
  margin-bottom: 12rpx;
}

.tip-content {
  padding-top: 4rpx;
}

.tip-text {
  font-size: 26rpx;
  color: var(--color-text-light);
  line-height: 1.6;
}

/* ========== 操作按钮区（透明悬浮在底部） ========== */
.detail-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 16rpx;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: transparent;
  z-index: 100;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx 0;
  border-radius: var(--radius-lg);
  background: var(--color-bg-card);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
}

.action-icon {
  font-size: 28rpx;
}

.action-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.action-delete .action-text {
  color: var(--color-error);
}

/* ========== 底部间距（为悬浮按钮留空） ========== */
.detail-footer {
  height: 140rpx;
}
