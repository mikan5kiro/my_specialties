<wxs module="utils">
  function hasValue(arr, value) {
    for (var i = 0; i < arr.length; i++) {
      if (arr[i] === value) {
        return true;
      }
    }
    return false;
  }
  module.exports = {
    hasValue: hasValue
  }
</wxs>
<!-- 首页 - 搜索+排序+筛选 三合一 -->
<view class="home-container">
  <!-- 页面头部 -->
  <view class="page-header">
    <text class="page-header-icon">🍳</text>
    <view class="page-header-text">
      <view class="page-header-title">我的食谱本</view>
      <view class="page-header-subtitle">记录美味时光</view>
    </view>
  </view>

  <!-- 搜索框 -->
  <view class="search-bar">
    <text class="search-bar-icon">🔍</text>
    <input
      class="search-bar-input"
      placeholder="搜索食谱..."
      value="{{searchKeyword}}"
      bindinput="onSearchInput"
      confirm-type="search"
    />
    <text class="search-bar-clear" wx:if="{{searchKeyword}}" bindtap="clearSearch">✕</text>
  </view>

  <!-- 排序和筛选栏 -->
  <view class="sort-filter-bar">
    <!-- 下拉菜单（三Tab） -->
    <view class="sort-dropdown">
      <view class="sort-dropdown-trigger" bindtap="toggleSortDropdown">
        <text class="sort-dropdown-icon">{{currentSortIcon}}</text>
        <text class="sort-dropdown-text">{{currentSortText}}</text>
        <text class="sort-dropdown-arrow">{{sortDropdownOpen ? '▲' : '▼'}}</text>
      </view>
      <view class="sort-dropdown-menu" wx:if="{{sortDropdownOpen}}">
        <view
          class="sort-dropdown-item {{activeSort === 'default' ? 'active' : ''}}"
          bindtap="onSortSelect"
          data-sort="default"
        >
          <text class="sort-dropdown-item-icon">📋</text>
          <text>按添加顺序排序</text>
        </view>
        <view
          class="sort-dropdown-item {{activeSort === 'favorite' ? 'active' : ''}}"
          bindtap="onSortSelect"
          data-sort="favorite"
        >
          <text class="sort-dropdown-item-icon">❤️</text>
          <text>按喜爱程度排序</text>
        </view>
        <view
          class="sort-dropdown-item {{activeSort === 'frequent' ? 'active' : ''}}"
          bindtap="onSortSelect"
          data-sort="frequent"
        >
          <text class="sort-dropdown-item-icon">🔥</text>
          <text>按制作次数排序</text>
        </view>
        <view
          class="sort-dropdown-item {{activeSort === 'recent' ? 'active' : ''}}"
          bindtap="onSortSelect"
          data-sort="recent"
        >
          <text class="sort-dropdown-item-icon">📝</text>
          <text>最近想做</text>
        </view>
      </view>
    </view>

    <!-- 筛选按钮 -->
    <view class="filter-toggle-btn" bindtap="toggleFilterPanel">
      <text class="filter-toggle-icon">⚙️</text>
      <text class="filter-toggle-text">{{filterPanelOpen ? '收起' : '筛选'}}</text>
    </view>
  </view>

  <!-- 分割线 -->
  <view class="divider-line"></view>

  <!-- 标签筛选区（默认隐藏） -->
  <view class="filter-section" wx:if="{{filterPanelOpen}}">
    <!-- 食材标签 -->
    <view class="filter-group">
      <view class="filter-group-header" bindtap="toggleFilterGroup" data-group="ingredient">
        <view class="filter-group-title">🍖 食材</view>
        <text class="filter-group-arrow">{{filterExpand.ingredient ? '▼' : '▶'}}</text>
      </view>
      <view class="filter-group-body" wx:if="{{filterExpand.ingredient}}">
        <scroll-view class="filter-group-scroll hide-scrollbar" scroll-x enhanced show-scrollbar="{{false}}">
          <view class="filter-group-content">
            <view
              class="filter-chip {{utils.hasValue(selectedIngredients, 'all') ? 'active' : ''}}"
              bindtap="toggleIngredient"
              data-value="all"
            >全部</view>
            <view
              wx:for="{{ingredients}}"
              wx:key="value"
              class="filter-chip {{utils.hasValue(selectedIngredients, item.value) ? 'active' : ''}}"
              bindtap="toggleIngredient"
              data-value="{{item.value}}"
            >{{item.label}}</view>
          </view>
        </scroll-view>
        <view class="scroll-indicator">→</view>
      </view>
    </view>

    <!-- 类型标签 -->
    <view class="filter-group">
      <view class="filter-group-header" bindtap="toggleFilterGroup" data-group="type">
        <view class="filter-group-title">🍽️ 类型</view>
        <text class="filter-group-arrow">{{filterExpand.type ? '▼' : '▶'}}</text>
      </view>
      <view class="filter-group-body" wx:if="{{filterExpand.type}}">
        <scroll-view class="filter-group-scroll hide-scrollbar" scroll-x enhanced show-scrollbar="{{false}}">
          <view class="filter-group-content">
            <view
              class="filter-chip {{utils.hasValue(selectedTypes, 'all') ? 'active' : ''}}"
              bindtap="toggleType"
              data-value="all"
            >全部</view>
            <view
              wx:for="{{types}}"
              wx:key="value"
              class="filter-chip {{utils.hasValue(selectedTypes, item.value) ? 'active' : ''}}"
              bindtap="toggleType"
              data-value="{{item.value}}"
            >{{item.label}}</view>
          </view>
        </scroll-view>
        <view class="scroll-indicator">→</view>
      </view>
    </view>

    <!-- 场景标签 -->
    <view class="filter-group">
      <view class="filter-group-header" bindtap="toggleFilterGroup" data-group="scene">
        <view class="filter-group-title">🎉 场景</view>
        <text class="filter-group-arrow">{{filterExpand.scene ? '▼' : '▶'}}</text>
      </view>
      <view class="filter-group-body" wx:if="{{filterExpand.scene}}">
        <scroll-view class="filter-group-scroll hide-scrollbar" scroll-x enhanced show-scrollbar="{{false}}">
          <view class="filter-group-content">
            <view
              class="filter-chip {{utils.hasValue(selectedScenes, 'all') ? 'active' : ''}}"
              bindtap="toggleScene"
              data-value="all"
            >全部</view>
            <view
              wx:for="{{scenes}}"
              wx:key="value"
              class="filter-chip {{utils.hasValue(selectedScenes, item.value) ? 'active' : ''}}"
              bindtap="toggleScene"
              data-value="{{item.value}}"
            >{{item.label}}</view>
          </view>
        </scroll-view>
        <view class="scroll-indicator">→</view>
      </view>
    </view>
  </view>

  <!-- 统计信息 -->
  <view class="stats-bar">
    <text class="stats-text">共 {{filteredRecipes.length}} 个食谱</text>
  </view>

  <!-- 菜谱列表 -->
  <view class="recipe-grid">
    <view
      class="recipe-card"
      wx:for="{{filteredRecipes}}"
      wx:key="id"
      bindtap="goToDetail"
      data-id="{{item.id}}"
    >
      <view class="recipe-card-image-wrap">
        <image
          class="recipe-card-image"
          src="{{item.coverImage || '/images/default-goods-image.png'}}"
          mode="aspectFill"
          lazy-load
        />
      </view>
      <view class="recipe-card-info">
        <view class="recipe-card-header">
          <view class="recipe-card-title">{{item.name}}</view>
          <view class="recipe-card-tag">{{item.typeLabel}}</view>
        </view>
        <view class="recipe-card-meta">
          <view class="recipe-card-rating">
            <text class="star">★</text>
            <text class="score">{{item.rating}}</text>
          </view>
          <view class="recipe-card-count">
            <text style="color: var(--color-heart);">♥</text>
            <text>{{item.cookCount}}次</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{filteredRecipes.length === 0}}">
    <view class="empty-state-icon">🍳</view>
    <view class="empty-state-text">还没有食谱，快去添加吧~</view>
  </view>

  <!-- 悬浮添加按钮 -->
  <view class="fab" bindtap="goToAdd">+</view>
</view>
