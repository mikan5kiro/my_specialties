/** 首页样式 */

@import '../../styles/components.wxss';

.home-container {
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* 统计栏 */
.stats-bar {
  padding: 16rpx 32rpx;
}

.stats-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

/* 首页特有的卡片网格微调 */
.recipe-grid {
  padding: 0 32rpx 32rpx;
}

/* 响应式：单列布局（可选） */
@media (max-width: 375px) {
  .recipe-grid {
    grid-template-columns: 1fr;
  }
}

.filter-chip.active {
  background: #ffb900 !important;
  color: #ffffff !important;
  border-color: #ffb900 !important;
}

/* 首页 emoji 调大 */
.sort-dropdown-item-icon {
  font-size: 32rpx;
}

.recipe-card-rating .star,
.recipe-card-count {
  font-size: 28rpx;
}

/* 首页加号按钮 - 主题色纯色 */
.fab {
  background: var(--color-primary) !important;
  color: #ffffff !important;
}