/** 首页样式 */

.home-container {
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* 统计栏 */
.stats-bar {
  padding: 16rpx 32rpx;
}

.stats-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

/* 首页特有的卡片网格微调 */
.recipe-grid {
  padding: 0 32rpx 32rpx;
}

/* 响应式：单列布局（可选） */
@media (max-width: 375px) {
  .recipe-grid {
    grid-template-columns: 1fr;
  }
}
